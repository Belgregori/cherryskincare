# ============================================
# PERFIL DE DESARROLLO - ARCHIVO DE EJEMPLO
# ============================================
# Copia este archivo como application-dev.properties y completa los valores
# O usa variables de entorno del sistema
#
# Para usar este perfil:
# 1. Copia este archivo: cp application-dev.properties.example application-dev.properties
# 2. Completa los valores o configura variables de entorno
# 3. Activa el perfil: spring.profiles.active=dev
#    O usa: SPRING_PROFILES_ACTIVE=dev
# ============================================

# Base de datos MySQL (desarrollo local)
spring.datasource.url=jdbc:mysql://localhost:3306/cherry_skincare?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_AQUI

# JWT Configuration
# IMPORTANTE: Genera una clave secreta segura (mínimo 256 bits)
# Puedes usar: openssl rand -base64 32
jwt.secret=TU_JWT_SECRET_AQUI_MINIMO_32_CARACTERES_SEGUROS
jwt.expiration=86400000
jwt.refresh-expiration=604800000

# JPA (desarrollo)
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=validate

# Logging (desarrollo - más verboso)
logging.level.com.cherryskincare=DEBUG

# Admin User Configuration (desarrollo)
# Solo para desarrollo local - configura estas variables
# Email por defecto con dominio con punto (válido para @Email en login y frontend)
admin.email=${ADMIN_EMAIL:admin@cherry.skincare}
admin.password=${ADMIN_PASSWORD:admin123}
# Habilitar creación de admin en desarrollo
admin.create-on-startup=true

# CORS (desarrollo)
cors.allowed-origins=http://localhost:5173,http://localhost:3000

# App Base URL
app.base-url=http://localhost:3000
